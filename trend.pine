//@version=5
indicator("MARKET TREND V5.0", overlay=true, max_lines_count=200, max_labels_count=100)

// ═══════════════════════════════════════════════════
// 1. INPUTS
// ═══════════════════════════════════════════════════
grpSweep  = "Sweep / BOS"
grpSR     = "Support & Resistance"
grpFilter = "Filters"
grpVis    = "Visuals"

swpLkbk   = input.int(8,     "Sweep Lookback",          group=grpSweep, minval=3,   maxval=20)
bosLkbk   = input.int(4,     "BOS Lookback",             group=grpSweep, minval=2,   maxval=10)
pvtLen    = input.int(8,     "S/R Pivot Length",         group=grpSR,    minval=3,   maxval=20)
zMult     = input.float(1.0, "Zone Thickness (ATR)",     group=grpSR,    minval=0.3, maxval=3.0, step=0.1)
srCluster = input.float(0.5, "S/R Cluster Filter (ATR)", group=grpSR,    minval=0.1, maxval=2.0, step=0.1)
atrLen    = input.int(14,    "ATR Length",               group=grpFilter,minval=5,   maxval=50)
tpMult    = input.float(2.0, "TP ATR Mult",              group=grpFilter,minval=0.5, maxval=5.0, step=0.1)
slMult    = input.float(1.5, "SL ATR Mult",              group=grpFilter,minval=0.3, maxval=3.0, step=0.1)
adxMin    = input.int(18,    "Min ADX",                  group=grpFilter,minval=10,  maxval=40)
htf1      = input.timeframe("15", "Trend TF 1 (EMA200)", group=grpFilter)
htf2      = input.timeframe("60", "Trend TF 2 (EMA50)",  group=grpFilter)
showSess  = input.bool(true, "Show Session Lines",        group=grpVis)

// ═══════════════════════════════════════════════════
// 2. CORE INDICATORS
// ═══════════════════════════════════════════════════
atr   = ta.atr(atrLen)
[_dp, _dm, adx] = ta.dmi(14, 14)
ema9  = ta.ema(close, 9)
ema21 = ta.ema(close, 21)
ema50 = ta.ema(close, 50)

htfEma200 = request.security(syminfo.tickerid, htf1, ta.ema(close, 200), lookahead=barmerge.lookahead_off)
htfEma50  = request.security(syminfo.tickerid, htf2, ta.ema(close, 50),  lookahead=barmerge.lookahead_off)
trndBll   = close > htfEma200 and close > htfEma50
trndBer   = close < htfEma200 and close < htfEma50

dHi = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
dLo = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_on)
plot(dHi, "Daily High", color=color.new(color.red,   25), style=plot.style_stepline, linewidth=2)
plot(dLo, "Daily Low",  color=color.new(color.green, 25), style=plot.style_stepline, linewidth=2)

// ═══════════════════════════════════════════════════
// 3. PROBABILITY SCORING
// ═══════════════════════════════════════════════════
f_prob(isL) =>
    p = 0.0
    p += (isL ? trndBll : trndBer) ? 35.0 : 0.0
    p += adx > 30 ? 25.0 : adx > 22 ? 18.0 : adx > adxMin ? 10.0 : 0.0
    p += (isL ? ema9 > ema21  : ema9  < ema21) ? 15.0 : 0.0
    p += (isL ? ema21 > ema50 : ema21 < ema50) ? 10.0 : 0.0
    p += (isL ? close > open  : close < open)  ? 10.0 : 0.0
    nearDayLvl = isL ? low < dLo + atr * 1.5 : high > dHi - atr * 1.5
    p += nearDayLvl ? 5.0 : 0.0
    math.min(p, 100.0)

// ═══════════════════════════════════════════════════
// 4. SESSION SEPARATORS
// ═══════════════════════════════════════════════════
isLondonOpen = hour(time, "UTC") == 8  and minute(time, "UTC") == 0
isNYOpen     = hour(time, "UTC") == 13 and minute(time, "UTC") == 0

if showSess and isLondonOpen
    line.new(bar_index, low - atr * 2, bar_index, high + atr * 2, extend=extend.both, style=line.style_dashed, color=color.new(color.orange, 50), width=1)
    label.new(bar_index, high + atr * 2, "LONDON", style=label.style_none, textcolor=color.new(color.orange, 30), size=size.tiny)

if showSess and isNYOpen
    line.new(bar_index, low - atr * 2, bar_index, high + atr * 2, extend=extend.both, style=line.style_dashed, color=color.new(color.aqua, 50), width=1)
    label.new(bar_index, high + atr * 2, "NY", style=label.style_none, textcolor=color.new(color.aqua, 30), size=size.tiny)

// ═══════════════════════════════════════════════════
// 5. S/R LEVELS (lines only, no boxes)
// ═══════════════════════════════════════════════════
ph = ta.pivothigh(pvtLen, pvtLen)
pl = ta.pivotlow(pvtLen, pvtLen)

// ═══════════════════════════════════════════════════
// 6. LIQUIDITY SWEEP (wick-based)
// ═══════════════════════════════════════════════════
swpL = low  < ta.lowest(low[1],   swpLkbk) and close > ta.lowest(low[1],   swpLkbk)
swpH = high > ta.highest(high[1], swpLkbk) and close < ta.highest(high[1], swpLkbk)

var int bSwpL = 999
var int bSwpH = 999
bSwpL := swpL ? 0 : math.min(bSwpL + 1, 999)
bSwpH := swpH ? 0 : math.min(bSwpH + 1, 999)

// ═══════════════════════════════════════════════════
// 7. BOS DETECTION (no order block boxes)
// ═══════════════════════════════════════════════════
bosBll = ta.crossover( close, ta.highest(high[1], bosLkbk))
bosBer = ta.crossunder(close, ta.lowest(low[1],   bosLkbk))

// ═══════════════════════════════════════════════════
// 8. GOLDEN ZONE (logic only, no box)
// ═══════════════════════════════════════════════════
var float gzH    = na
var float gzL    = na
var int   gzTyp  = 0
var bool  gzUsed = false

if not na(gzH) and not na(gzL)
    if math.abs(close - (gzH + gzL) / 2) > atr * 4
        gzTyp  := 0
        gzH    := na
        gzL    := na
        gzUsed := false

if (bosBll and bSwpL <= 10) or (bosBer and bSwpH <= 10)
    gzTyp  := bosBll ? 1 : -1
    gzH    := high[bosLkbk]
    gzL    := low[bosLkbk]
    gzUsed := false

// ═══════════════════════════════════════════════════
// 9. ENTRY SIGNALS
// ═══════════════════════════════════════════════════
adxOk = adx > adxMin
buyS  = gzTyp == 1  and not gzUsed and low  <= gzH and close > gzL and adxOk and trndBll
selS  = gzTyp == -1 and not gzUsed and high >= gzL and close < gzH and adxOk and trndBer

// ═══════════════════════════════════════════════════
// 10. POSITION ENGINE
// ═══════════════════════════════════════════════════
var float[] t = array.new_float(10, 0.0)

if array.get(t, 0) == 1.0
    isL_t = array.get(t, 1) == 1.0
    tp_t  = array.get(t, 3)
    sl_t  = array.get(t, 4)
    array.set(t, 5, math.abs(tp_t - close) / math.max(math.abs(close - sl_t), 0.001))
    array.set(t, 6, f_prob(isL_t))
    hitL  = isL_t  and (high >= tp_t or low <= sl_t)
    hitS  = not isL_t and (low <= tp_t or high >= sl_t)
    if hitL or hitS
        array.set(t, 0, 0.0)
        gzUsed := true

else if buyS or selS
    isL_e = buyS
    slP   = isL_e ? close - atr * slMult : close + atr * slMult
    tpP   = isL_e ? close + atr * tpMult : close - atr * tpMult
    array.set(t, 0, 1.0)
    array.set(t, 1, isL_e ? 1.0 : -1.0)
    array.set(t, 2, close)
    array.set(t, 3, tpP)
    array.set(t, 4, slP)
    array.set(t, 5, tpMult / slMult)
    array.set(t, 6, f_prob(isL_e))
    array.set(t, 7, bar_index)
    array.set(t, 8, time)

// ═══════════════════════════════════════════════════
// 11. POSITION VISUALS (lines & labels only, no boxes)
// ═══════════════════════════════════════════════════
var line  lEnt   = na
var line  lTP    = na
var line  lSL    = na
var label lbMain = na
var label lbTP   = na
var label lbSL   = na

line.delete(lEnt)
line.delete(lTP)
line.delete(lSL)
label.delete(lbMain)
label.delete(lbTP)
label.delete(lbSL)

if array.get(t, 0) == 1.0
    eIdx    = bar_index + 20
    ent     = array.get(t, 2)
    tp      = array.get(t, 3)
    sl      = array.get(t, 4)
    isL_v   = array.get(t, 1) == 1.0
    prob    = array.get(t, 6)
    liveRR  = array.get(t, 5)
    m_ago   = math.round((timenow - array.get(t, 8)) / 60000)
    eBarIdx = int(array.get(t, 7))
    rr_init = tpMult / slMult

    lEnt := line.new(eBarIdx, ent, eIdx, ent, color=color.new(color.white, 30), style=line.style_dotted, width=1)
    lTP  := line.new(eBarIdx, tp,  eIdx, tp,  color=color.lime, width=2)
    lSL  := line.new(eBarIdx, sl,  eIdx, sl,  color=color.red,  width=2)

    lbTP := label.new(eIdx, tp, "TP " + str.tostring(math.round(tp, 2)), style=label.style_label_left, color=color.new(color.lime, 20), textcolor=color.white, size=size.small)
    lbSL := label.new(eIdx, sl, "SL " + str.tostring(math.round(sl, 2)), style=label.style_label_left, color=color.new(color.red, 20),  textcolor=color.white, size=size.small)

    dirTxt  = isL_v ? "LONG" : "SHORT"
    colMain = isL_v ? color.new(color.blue, 10) : color.new(color.orange, 10)
    lbTxt   = dirTxt + "\nEntry: " + str.tostring(math.round(ent, 2)) + "\nProb: " + str.tostring(math.round(prob, 0)) + "%" + "\nRR 1:" + str.tostring(math.round(rr_init, 1)) + "\nLive RR: " + str.tostring(math.round(liveRR, 2)) + "\n" + str.tostring(m_ago) + "m ago"
    lbMain  := label.new(eIdx, ent, lbTxt, style=label.style_label_left, color=colMain, textcolor=color.white, size=size.small)

// ═══════════════════════════════════════════════════
// 12. DASHBOARD
// ═══════════════════════════════════════════════════
var table dash = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 5), border_width=1, border_color=color.new(color.gray, 60))

if barstate.islast
    hr     = hour(time, "UTC")
    sess   = hr >= 8 and hr < 13 ? "LONDON" : hr >= 13 and hr < 17 ? "LON/NY" : hr >= 17 and hr < 22 ? "NY" : "ASIA"
    isActv = array.get(t, 0) == 1.0
    posDir = array.get(t, 1) == 1.0

    table.cell(dash, 0, 0, "GOLD V8", text_color=color.yellow, text_size=size.normal)
    table.cell(dash, 1, 0, "SCALPER", text_color=color.yellow, text_size=size.normal)

    table.cell(dash, 0, 1, "Session", text_color=color.new(color.silver, 10), text_size=size.small)
    table.cell(dash, 1, 1, sess, text_color=color.white, text_size=size.small)

    table.cell(dash, 0, 2, "ADX", text_color=color.new(color.silver, 10), text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(math.round(adx, 1)), text_color=adx > 25 ? color.lime : adx > adxMin ? color.yellow : color.red, text_size=size.small)

    table.cell(dash, 0, 3, "HTF", text_color=color.new(color.silver, 10), text_size=size.small)
    table.cell(dash, 1, 3, trndBll ? "BULL" : trndBer ? "BEAR" : "MIXED", text_color=trndBll ? color.lime : trndBer ? color.red : color.gray, text_size=size.small)

    table.cell(dash, 0, 4, "EMA", text_color=color.new(color.silver, 10), text_size=size.small)
    table.cell(dash, 1, 4, ema9 > ema21 ? "BULL" : "BEAR", text_color=ema9 > ema21 ? color.lime : color.red, text_size=size.small)

    table.cell(dash, 0, 5, "Pos", text_color=color.new(color.silver, 10), text_size=size.small)
    table.cell(dash, 1, 5, isActv ? (posDir ? "LONG" : "SHORT") : "FLAT", text_color=isActv ? (posDir ? color.lime : color.red) : color.gray, text_size=size.small)

    table.cell(dash, 0, 6, "Prob", text_color=color.new(color.silver, 10), text_size=size.small)
    table.cell(dash, 1, 6, str.tostring(math.round(array.get(t, 6), 0)) + "%", text_color=color.yellow, text_size=size.small)

    table.cell(dash, 0, 7, "Live RR", text_color=color.new(color.silver, 10), text_size=size.small)
    table.cell(dash, 1, 7, str.tostring(math.round(array.get(t, 5), 2)), text_color=color.aqua, text_size=size.small)
